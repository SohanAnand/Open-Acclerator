# GitHub
GITHUB_TOKEN=
GITHUB_REPO=org/repo

# Ingest + RAG (file-backed Chroma; no cloud vector DB required)
CHROMA_DIR=./data/chroma
BM25_PKL=
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBED_DEVICE=cpu

# vLLM (OpenAI-compatible, naive path)
VLLM_BASE_URL=http://127.0.0.1:8000/v1
VLLM_MODEL=
# PrefixPilot (routed path; RAG /v1/triage_routed)
PREFIX_PILOT_URL=http://127.0.0.1:8001
# Optional: set PREFIX_DEBUG=1 to log prefix md5 on stderr

# RAG service
RAG_HOST=0.0.0.0
RAG_PORT=8080
COLLECTION=pr_triage

# Streamlit
RAG_BASE_URL=http://127.0.0.1:8080
